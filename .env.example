# Project Configuration
PROJECT_NAME="ai-backend"
ENVIRONMENT="development" # development, production, test
API_V1_STR="/api/v1"

# Security Configuration
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET="super-secret-jwt-key-change-in-production-1234567890"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate Limiting Configuration
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# PostgreSQL Configuration
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="securepassword"
POSTGRES_DB="aibackend"
POSTGRES_HOST="postgres"
POSTGRES_PORT=5432

# SQLAlchemy Async Connection URL (used inside Docker Compose)
# For local running outside docker, use localhost instead of postgres host
DATABASE_URL="postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# Redis Configuration (used inside Docker Compose)
# For local running outside docker, use localhost instead of redis host
REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_URL="redis://${REDIS_HOST}:${REDIS_PORT}/0"
